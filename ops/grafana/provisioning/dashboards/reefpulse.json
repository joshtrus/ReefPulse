{
  "uid": "reefpulse",
  "title": "ReefPulse — Reef Monitoring",
  "tags": ["reefpulse"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Readings persisted (per sec)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(reef_readings_persisted_total[1m]))",
          "legendFormat": "persisted/s"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Readings published (per sec)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(reef_readings_published_total[1m]))",
          "legendFormat": "published/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Active bleaching alerts",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(reef_alerts_opened_total) - sum(reef_alerts_resolved_total)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Alerts opened (total)",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(reef_alerts_opened_total)"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Ingest lag p95 (seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(reef_ingest_lag_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 lag (s)"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP request rate",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_server_request_duration_seconds_count[1m]))",
          "legendFormat": "req/s"
        }
      ]
    }
  ]
}
