{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Ingestion": {
    "Enabled": false,
    "IntervalMinutes": 10
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "ReadingsTopic": "reef.readings",
    "ConsumerGroup": "reefpulse-consumers"
  },
  "Bleaching": {
    "TemperatureThresholdCelsius": 30.5
  }
}
